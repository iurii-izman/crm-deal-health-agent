OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
USE_OLLAMA=true

FAST_MODE=true
OLLAMA_FAST_MODEL=qwen3:1.7b
OLLAMA_QUALITY_MODEL=qwen3:4b

OLLAMA_THINK=false
OLLAMA_TIMEOUT_SECONDS=90
OLLAMA_NUM_CTX=2048
# In FAST_MODE=true: 300 tokens; FAST_MODE=false: 700 tokens (overridden in code)
OLLAMA_NUM_PREDICT=700
OLLAMA_TEMPERATURE=0.1

# Block B: Bitrix24
# Вставлять без имени метода, только базу webhook:
# https://your-domain.bitrix24.ru/rest/1/your_webhook_code/
BITRIX_WEBHOOK_URL=
BITRIX_RESPONSIBLE_ID=1

# App Mode
APP_MODE=demo
ALLOW_BITRIX_WRITE=false

# Block D: Bitrix24 Outgoing Webhook Handler (Event-Driven Mode)
# BITRIX_EVENT_SECRET — наш секрет, передаётся в handler URL через ?secret=...
# Вставлять в Битрикс24 → Робот "Исходящий Вебхук" → поле "Хендлер":
# https://<public-tunnel-domain>/bitrix/outgoing-webhook?secret=<BITRIX_EVENT_SECRET>
BITRIX_EVENT_SECRET=change-me

# BITRIX_OUTGOING_TOKEN — опциональный токен, который Bitrix24 присылает в payload
# Если задан, проверяется сравнением с входящим токеном
BITRIX_OUTGOING_TOKEN=

# TTL в секундах для защиты от повторной обработки одного события
EVENT_IDEMPOTENCY_TTL_SECONDS=600

# Только для локальной отладки входящих событий (без вывода секретов)
DEBUG_INCOMING_EVENTS=false
